# ============================================================
# DPS-Monitor Backend — Environment Variables
# Скопіюй у .env і заповни реальними значеннями
# ============================================================

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
# Railway виставляє PORT автоматично — локально використовуй 3001
PORT=3001

# Vercel URL фронтенду — дозволяється в CORS
# Для кількох origins: через кому без пробілів
# FRONTEND_URL=https://dps-monitor.vercel.app,https://dps-monitor-staging.vercel.app
FRONTEND_URL=https://dps-monitor.vercel.app

# ------------------------------------------------------------
# Supabase — та сама БД що у /web
# ------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
# Service role key — обходить RLS. НІКОЛИ не давати в браузер.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------------------------
# Шифрування — сумісність з /web/lib/crypto.ts
# ------------------------------------------------------------
# Той самий секрет що у /web TOKEN_ENCRYPTION_KEY.
# Потрібен для читання існуючих AES-зашифрованих КЕП з БД.
# НЕ ЗМІНЮВАТИ — інакше старі записи стануть нечитабельними.
TOKEN_ENCRYPTION_KEY=your-token-encryption-key

# ------------------------------------------------------------
# AWS KMS
# ------------------------------------------------------------
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# ARN або alias CMK ключа
AWS_KMS_KEY_ID=arn:aws:kms:eu-central-1:123456789012:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ------------------------------------------------------------
# Auth між сервісами
# ------------------------------------------------------------
# Shared secret між /web і /backend.
# /web надсилає його в заголовку X-Backend-Secret.
# Мінімум 32 випадкових символи. Генерувати: openssl rand -hex 32
BACKEND_API_SECRET=your-strong-random-secret-min-32-chars

# Той самий CRON_SECRET що у /web — для захисту ендпоінтів
# які можуть викликатись планувальником Railway або зовнішнім cron.
CRON_SECRET=your-cron-secret
