{
  "name": "dps-monitor-backend",
  "version": "1.0.0",
  "private": true,
  "description": "DPS Monitor backend service — Railway deployment, AWS KMS KEP encryption",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "security-check": "ts-node --transpile-only -P tsconfig.scripts.json -r dotenv/config scripts/security-check.ts",
    "test": "jest",
    "test:security": "jest kepSecurity"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.600.0",
    "@supabase/supabase-js": "^2.99.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
